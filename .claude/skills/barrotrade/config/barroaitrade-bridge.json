  "code_evolution_policy": {
    "scope": "dataclass_numeric_fields_only",
    "scope_description": "오직 @dataclass 안의 숫자 필드만 수정 가능. 함수 로직·조건문·문자열·타입 변경 절대 금지.",
    "allowed_change_types": [
